{
  "name": "context-hub-mcp",
  "version": "0.1.1",
  "description": "Opinionated .context-first MCP server for local knowledge retrieval via stdio.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "context-hub-mcp": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format esm --dts --clean",
    "dev": "tsx src/cli/index.ts",
    "pack:json": "npm pack --json",
    "prepublish-check": "npm test && npm run typecheck && npm run build && npm run pack:json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "knowledge-base",
    "sqlite",
    "markdown",
    "context"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.1",
    "glob": "^11.0.3",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
